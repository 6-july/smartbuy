  "info": {
    "title": "SmartBuy 服务端 API",
    "description": "智能导购小程序 MVP 服务端接口",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "adminToken": {
        "type": "apiKey",
        "in": "header",
        "name": "x-admin-token"
      }
    },
    "schemas": {
      "WechatUserInfoDto": {
        "type": "object",
        "properties": {
          "nickname": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          }
        }
      },
      "WechatLoginDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "wx.login 返回的一次性 code"
          },
          "userInfo": {
            "$ref": "#/components/schemas/WechatUserInfoDto"
          }
        },
        "required": [
          "code"
        ]
      },
      "ScanMerchantDto": {
        "type": "object",
        "properties": {
          "scene": {
            "type": "string",
            "example": "m_abcd1234"
          }
        },
        "required": [
          "scene"
        ]
      },
      "CreateMerchantDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "bannerImage": {
            "type": "string"
          },
          "miniProgramAppId": {
            "type": "string"
          },
          "recommendQuestions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "phone": {
            "type": "string",
            "description": "客服电话"
          },
          "address": {
            "type": "string",
            "description": "商家门店地址"
          },
          "industry": {
            "type": "string",
            "description": "行业（如 蛋糕烘焙、鲜花、水果）",
            "default": "综合零售"
          }
        },
        "required": [
          "name",
          "miniProgramAppId"
        ]
      },
      "ProductImportItemDto": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "example": "youzan"
          },
          "sourceShopId": {
            "type": "string"
          },
          "sourceProductId": {
            "type": "string"
          },
          "alias": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "displayPrice": {
            "type": "number"
          },
          "minPrice": {
            "type": "number"
          },
          "maxPrice": {
            "type": "number"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sales": {
            "type": "number"
          },
          "isRecommended": {
            "type": "boolean"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "optionsText": {
            "type": "string"
          }
        },
        "required": [
          "source",
          "sourceProductId",
          "title",
          "displayPrice",
          "minPrice",
          "maxPrice",
          "images",
          "sales",
          "isRecommended",
          "options",
          "tags",
          "optionsText"
        ]
      },
      "ImportProductsDto": {
        "type": "object",
        "properties": {
          "merchantId": {
            "type": "string"
          },
          "products": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductImportItemDto"
            }
          },
          "deactivateMissing": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "merchantId",
          "products"
        ]
      },
      "Object": {
        "type": "object",
        "properties": {}
      },
      "UpdateProductStatusDto": {
        "type": "object",
        "properties": {
          "saleStatus": {
            "type": "string",
            "enum": [
              "on_sale",
              "off_sale"
            ]
          }
        },
        "required": [
          "saleStatus"
        ]
      },
      "SendMessageDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "example": "200元以内有什么抹茶蛋糕？"
          },
          "clientMessageId": {
            "type": "string",
            "description": "客户端为每次发送生成的幂等 ID"
          }
        },
        "required": [
          "content",
          "clientMessageId"
        ]
      }
    }
  }
}
