# 基础服务配置
# PORT：BFF 服务监听端口，默认使用 3000。
# DATABASE_URL：PostgreSQL 连接地址，格式为 postgresql://用户名:密码@主机:端口/数据库名。
# JWT_SECRET：小程序用户登录令牌的签名密钥，部署时必须替换为高强度随机值。
# JWT_EXPIRES_IN：小程序用户登录令牌有效期，例如 7d 表示 7 天。
PORT=3000
DATABASE_URL=postgresql://root:change-me@192.168.4.60:5432/uu_ailab_smartbuy
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# 内部管理接口鉴权
# ADMIN_SERVICE_TOKEN：调用 /api/admin/* 时通过 x-admin-token 请求头传递。
# 必须使用高强度随机值，严禁写入小程序或浏览器前端代码。
ADMIN_SERVICE_TOKEN=replace-with-a-long-random-admin-token

# 微信小程序配置
# WECHAT_MOCK_ENABLED：是否启用微信登录模拟，仅限本地开发使用，生产环境必须为 false。
# WECHAT_PLATFORM_APP_ID：平台微信小程序的 AppID。
# WECHAT_PLATFORM_APP_SECRET：平台微信小程序的 AppSecret，严禁提交到版本库或暴露给前端。
WECHAT_MOCK_ENABLED=false
WECHAT_PLATFORM_APP_ID=
WECHAT_PLATFORM_APP_SECRET=

# 对话模型配置
# AI_CHAT_API_URL：兼容 OpenAI Chat Completions 协议的接口地址。
# AI_CHAT_API_KEY：对话模型接口密钥，严禁暴露给前端。
# AI_CHAT_MODEL：调用的对话模型名称；三项留空时使用本地规则生成兜底回复。
AI_CHAT_API_URL=
AI_CHAT_API_KEY=
AI_CHAT_MODEL=

# Langfuse 观测配置
# LANGFUSE_PUBLIC_KEY：Langfuse 项目的 Public Key，用于标识写入的项目。
# LANGFUSE_SECRET_KEY：Langfuse 项目的 Secret Key，用于服务端上报 trace，严禁暴露给前端。
# LANGFUSE_BASE_URL：Langfuse 服务地址；使用官方云服务时填 https://cloud.langfuse.com，自部署时填自部署地址。
# LANGFUSE_EXPORT_MODE：trace 上报模式；本地调试推荐 immediate，生产长跑服务推荐 batched。
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_EXPORT_MODE=batched

# 业务参数
# PRODUCT_PATH_TEMPLATE_YOUZAN：有赞商品详情页路径模板，{alias} 会替换为商品别名。
# CONVERSATION_REUSE_WINDOW_MINUTES：同一用户再次进入同一商家时复用会话的时间窗口，单位为分钟。
# MESSAGE_PROCESSING_TIMEOUT_SECONDS：消息处理超过该秒数后允许相同 clientMessageId 重新执行。
PRODUCT_PATH_TEMPLATE_YOUZAN=/pages/goods/detail/index?alias={alias}
CONVERSATION_REUSE_WINDOW_MINUTES=30
MESSAGE_PROCESSING_TIMEOUT_SECONDS=120
